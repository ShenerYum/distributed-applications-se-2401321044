# Redirect all requests to HTTPS, then route through the public folder while preserving the root host
RewriteEngine On
RewriteBase /

# Redirect HTTP to HTTPS on standard port 443
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP_HOST} ^([^:]+)(?::\d+)?$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# Use public/index.php as the directory index
DirectoryIndex index.php

# Do not rewrite requests that already target the public folder
RewriteRule ^public/ - [L]

# Serve existing files and directories directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Otherwise rewrite everything to public/
RewriteRule ^(.*)$ public/$1 [L,QSA]
